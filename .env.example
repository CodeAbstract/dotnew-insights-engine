# Database Configuration
DATABASE_URL=postgresql://localhost/dotnew_insights_engine_development
TEST_DATABASE_URL=postgresql://localhost/dotnew_insights_engine_test

# Rails Configuration
RAILS_ENV=development
RAILS_MAX_THREADS=5
WEB_CONCURRENCY=2
PORT=3000

# Rate Limiting
GLOBAL_RATE_LIMIT=300
GLOBAL_RATE_LIMIT_PERIOD=300
TRACK_RATE_LIMIT=60
TRACK_RATE_LIMIT_PERIOD=60

# Security
RAILS_MASTER_KEY=your_master_key_here
SECRET_KEY_BASE=your_secret_key_base_here

# GeoIP Configuration
GEOIP_LICENSE_KEY=your_geoip_license_key_here
GEOIP_ACCOUNT_ID=your_geoip_account_id_here

# API Configuration
API_RATE_LIMIT_MAX_REQUESTS=100
API_RATE_LIMIT_WINDOW=300
