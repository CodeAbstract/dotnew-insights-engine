# See https://help.github.com/articles/ignoring-files for more about ignoring files.
#
# Temporary files generated by your text editor or operating system
# belong in git's global ignore instead:
# `$XDG_CONFIG_HOME/git/ignore` or `~/.config/git/ignore`

# Environment files
.env
.env.*
!.env.example

# Rails specific
/.bundle
/log/*
/tmp/*
!/log/.keep
!/tmp/.keep
/tmp/pids/*
!/tmp/pids/
!/tmp/pids/.keep
/storage/*
!/storage/.keep
/tmp/storage/*
!/tmp/storage/
!/tmp/storage/.keep

# Ignore master key and credentials
/config/master.key
/config/credentials/*.key
/config/credentials.yml.enc

# Database
/db/*.sqlite3
/db/*.sqlite3-*

# Testing
/coverage/*
.rspec_status

# Logs and temp files
*.log
*.swp
.DS_Store
.byebug_history

# IDE specific
.idea/
.vscode/
*.sublime-project
*.sublime-workspace

# Documentation
/doc/
/rdoc/
